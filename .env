# ============================================
# Learning 前端环境变量配置
# ============================================

# 应用标识（必须与后端 ALLOWED_APPS 中的应用ID一致）
VITE_APP_ID=learning
VITE_APP_NAME=Learning

# API 配置
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_AUTH_CENTER_URL=http://localhost:8000/api/v1/core/auth/center

# 当前应用地址
VITE_APP_URL=http://localhost:3003

# 开发服务器端口
PORT=3003

# 是否自动打开浏览器（none 表示不打开）
BROWSER=none
