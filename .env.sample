# ============================================
# Learning 前端环境变量配置模板
# 复制此文件为 .env 并修改配置
# ============================================

# 应用标识（必须与后端 ALLOWED_APPS 中的应用ID一致）
VITE_APP_ID=learning
VITE_APP_NAME=Learning

# API 配置
VITE_API_BASE_URL=https://bk.sample.com/api/v1
VITE_AUTH_CENTER_URL=https://bk.sample.com/api/v1/core/auth/center

# 当前应用地址
VITE_APP_URL=https://learning.sample.com

# 环境标识
VITE_ENV=production
